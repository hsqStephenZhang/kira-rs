decl @getint(): i32

decl @getch(): i32

decl @getarray(*i32): i32

decl @putint(i32)

decl @putch(i32)

decl @putarray(i32, *i32)

decl @starttime()

decl @stoptime()

fun @main(): i32 {
%entry:
  %ret = alloc i32
  @temp = alloc i32
  jump %0

%0:
  store 0, @temp
  %1 = load @temp
  %2 = sub %1, 1
  store %2, @temp
  %3 = load @temp
  %4 = gt 1, %3
  store %4, %ret
  jump %end

%5:
  jump %end

%end:
  %6 = load %ret
  ret %6
}
